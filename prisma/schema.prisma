// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MECHANIC
  ADMIN
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  DONE
  PAID
  DELIVERED
  EXPIRED
}

enum QuoteStatus {
  PENDING // Mechanic submitted, waiting for user
  ACCEPTED // User chose this quote
  REJECTED // User dismissed this mechanic's quote
  WITHDRAWN // Mechanic withdrew their quote
}

enum PaymentMethod {
  PLATFORM // User pays platform; we take 20%, pay mechanic 80%
  DIRECT // User pays mechanic directly; mechanic pays us 20%
}

enum TransactionType {
  USER_PAYMENT // User paid platform for a booking (Paystack)
  PLATFORM_PAYOUT // Platform paid mechanic their 80%
  MECHANIC_FEE // Mechanic paid platform their 20% (for direct bookings)
  REFUND // Platform refunded user
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationRecipientRole {
  USER
  MECHANIC
}

enum VehicleType {
  SEDAN
  SUV
  TRUCK
  BIKE
}

enum FaultCategory {
  ENGINE
  BRAKES
  ELECTRICAL
  AC
  TRANSMISSION
  OTHER
}

model AccountDeletionLog {
  id         String   @id @default(uuid())
  role       String // USER | MECHANIC
  reasons    Json // string[]
  otherText  String?
  createdAt  DateTime @default(now())
}

model InAppNotification {
  id              String                    @id @default(uuid())
  recipientRole   NotificationRecipientRole
  recipientId     String
  type            String
  title           String
  body            String
  data            Json?
  readAt          DateTime?
  createdAt       DateTime                  @default(now())

  @@index([recipientRole, recipientId, readAt])
  @@index([recipientRole, recipientId, createdAt(sort: Desc)])
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String?
  lastName      String?
  dateOfBirth   DateTime?
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false)
  emailToken    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile      UserProfile?
  vehicles     Vehicle[]
  bookings     Booking[]
  givenRatings Rating[]      @relation("UserRatings")
  transactions Transaction[]
  blockedMechanics UserBlocksMechanic[]
  expoPushToken    String?
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  phone     String?
  address   String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mechanic {
  id              String    @id @default(uuid())
  userId          String    @unique
  companyName     String
  ownerFullName   String
  email           String    @unique
  password        String
  emailVerified   Boolean   @default(false)
  emailToken      String?
  profileComplete Boolean   @default(false)
  isVerified      Boolean   @default(false) // Admin verification - only verified mechanics shown in search
  deletedAt       DateTime? // Soft delete: account closed, history retained for bookings/ratings
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile         MechanicProfile?
  bankAccounts    MechanicBankAccount[]
  bookings        Booking[]
  receivedRatings Rating[]               @relation("MechanicRatings")
  quotes          BookingQuote[]
  clarifications  BookingClarification[]
  transactions    Transaction[]
  blockedByUsers  UserBlocksMechanic[]
  expoPushToken   String?
}

model MechanicBankAccount {
  id                     String   @id @default(uuid())
  mechanicId             String
  bankCode               String   // e.g. 058 for GTBank (Paystack bank code)
  bankName               String   // e.g. "Guaranty Trust Bank"
  accountNumber          String
  accountName            String   // Beneficiary name on the account
  isDefault              Boolean  @default(false)
  /** Paystack transfer recipient code — reused for withdrawals to avoid duplicate recipients. */
  paystackRecipientCode  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@unique([mechanicId, accountNumber])
}

model MechanicProfile {
  id               String   @id @default(uuid())
  mechanicId       String   @unique
  phone            String?
  address          String?
  city             String?
  state            String?
  zipCode          String?
  latitude         Float?
  longitude        Float?
  avatar           String?
  bio              String?
  availability     Boolean  @default(true)
  expertise        String[] // MECHANICAL (engine/brakes/transmission), ELECTRICAL, AC, OTHER
  vehicleTypes     String[] // SALOON, SUV, TRUCK (types mechanic works on)
  brands           String[] @default([]) // Car brands mechanic works on (e.g. Toyota, Honda)
  experience       String? // e.g. "5 years", "10+ years"
  workshopAddress  String? // Location of workshop
  certificateUrl   String? // Cloudinary URL for certificate document
  /** Shown on profile/cards: typical hours until first response (e.g. 24) */
  typicalResponseHours Int?
  /** Free text e.g. "Earliest slot: tomorrow afternoon" */
  nextAvailableNote    String?
  guarantorName    String?
  guarantorPhone   String?
  guarantorAddress String?
  nin              String? // National Identification Number
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id           String      @id @default(uuid())
  userId       String
  type         VehicleType
  brand        String
  model        String
  year         Int
  color        String?
  licensePlate String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Fault {
  id          String        @id @default(uuid())
  category    FaultCategory
  name        String
  description String?
  questions   Json? // Array of guided questions
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  bookings Booking[]
}

model Booking {
  id                String         @id @default(uuid())
  userId            String
  mechanicId        String?
  vehicleId         String
  faultId           String
  status            BookingStatus  @default(REQUESTED)
  description       String?
  locationLat       Float?
  locationLng       Float?
  locationAddress   String?
  estimatedCost     Float?
  actualCost        Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  acceptedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  paidAt            DateTime?
  deliveredAt       DateTime?
  paymentMethod     PaymentMethod?
  paidAmount        Float? // Amount actually paid (for platform: from Paystack; for direct: agreed amount)
  paystackReference String? // Paystack reference when user pays via platform
  disputeReason     String? // Set when user/mechanic raises a dispute
  disputeResolvedAt DateTime? // When admin resolved it
  resolvedById      String? // Admin user id who resolved
  photoUrls         String[]             @default([])
  /** Open-board requests only: auto-expire after this time */
  openRequestExpiresAt DateTime?

  user           User                   @relation(fields: [userId], references: [id])
  mechanic       Mechanic?              @relation(fields: [mechanicId], references: [id])
  vehicle        Vehicle                @relation(fields: [vehicleId], references: [id])
  fault          Fault                  @relation(fields: [faultId], references: [id])
  messages       Message[]
  ratings        Rating[]
  quotes         BookingQuote[]
  clarifications BookingClarification[]
  transactions   Transaction[]
  reports        BookingReport[]
}

model BookingReport {
  id           String   @id @default(uuid())
  bookingId    String
  reporterId   String // User.id or Mechanic.id depending on reporterRole
  reporterRole String // USER | MECHANIC
  reason       String
  details      String?
  createdAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model UserBlocksMechanic {
  id String   @id @default(uuid())
  userId     String
  mechanicId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@unique([userId, mechanicId])
}

model BookingQuote {
  id            String      @id @default(uuid())
  bookingId     String
  mechanicId    String
  proposedPrice Float
  message       String?
  status        QuoteStatus @default(PENDING)
  /** Number of times proposedPrice was changed after initial submit (caps revisions) */
  priceUpdateCount Int      @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@unique([bookingId, mechanicId])
}

model BookingClarification {
  id         String   @id @default(uuid())
  bookingId  String
  mechanicId String
  question   String
  answer     String?
  createdAt  DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
}

model Message {
  id           String   @id @default(uuid())
  bookingId    String
  senderId     String
  receiverId   String
  senderType   String // "USER" or "MECHANIC"
  receiverType String // "USER" or "MECHANIC"
  content      String
  read         Boolean  @default(false)
  readAt       DateTime?
  createdAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Rating {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  userId     String
  mechanicId String
  rating     Int // 1-5 stars
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user     User     @relation("UserRatings", fields: [userId], references: [id])
  mechanic Mechanic @relation("MechanicRatings", fields: [mechanicId], references: [id])
}

model Transaction {
  id                String            @id @default(uuid())
  type              TransactionType
  amountMinor       Int // Amount in kobo (NGN) or smallest currency unit
  currency          String            @default("NGN")
  status            TransactionStatus @default(PENDING)
  reference         String? // Internal reference
  paystackReference String? // Paystack reference for USER_PAYMENT
  userId            String?
  mechanicId        String?
  bookingId         String?
  description       String?
  metadata          Json?
  createdAt         DateTime          @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  mechanic Mechanic? @relation(fields: [mechanicId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])
}
