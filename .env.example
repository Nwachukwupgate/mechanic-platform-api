NODE_ENV=development
PORT=4000

# Use connection_limit=10 (or higher) so concurrent API requests don't time out.
# If you see "Timed out fetching a new connection from the connection pool (connection limit: 1)", add or increase connection_limit.
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require&connection_limit=10

JWT_SECRET=super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

EMAIL_FROM=no-reply@mechanicplatform.com
SMTP_HOST=smtp.mailprovider.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=xxxxxx

# Frontend: sibling folder mechanic-platform-frontend; set to its dev URL (e.g. http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Paystack: secret key for backend (initialize/verify); public key for frontend (popup/redirect)
PAYSTACK_SECRET_KEY=sk_test_c6a7e278002b601c047aa78948c568347f2d1843
PAYSTACK_PUBLIC_KEY=pk_test_311b7e355abacecbfa3097807660c7109a54659f

# First admin: set these and run `npx prisma db seed` to create/update admin user
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_secure_password

CLOUDINARY_CLOUD_NAME=dvvdrvodh
CLOUDINARY_API_KEY=511528288858657
CLOUDINARY_API_SECRET=lgcHQckdnkznntzvs6bkvEseBcQ
